# ===========================
# Generosity Pays - Environment Variables
# ===========================
# Copy this file to .env.local and fill in your values

# === Authentication ===
JWT_SECRET=your-secret-key-min-32-characters-change-this
ADMIN_DEFAULT_PASSWORD=          # Optional: set for first-run admin password. If blank, a random one is generated and printed to console.

# === Application ===
NODE_ENV=development
BASE_URL=http://localhost:3000

# === Email Notifications (optional — only sends if all SMTP vars are set) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@generositypays.net
ADMIN_EMAIL=                     # Email address to receive lead/contact notifications

# === Backups ===
BACKUP_RETENTION_DAYS=30
